# ─── Action Zone Server — Environment Variables ───────────────────────────────
# Copy this file to .env for local development.
# Railway sets PORT automatically — do NOT set it manually on Railway.

# Server port (local dev only)
PORT=3000

# CORS origin — set to your game's domain in production
# Use * to allow all origins (fine for public games)
CORS_ORIGIN=*

# Optional: max rooms allowed at once
# MAX_ROOMS=500

# Optional: Node environment
NODE_ENV=production
